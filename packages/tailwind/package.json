{
  "name": "zeroui-tailwind",
  "version": "0.1.0",
  "description": "ZERU UI React components styled for Tailwind CSS.",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["./src/styles/styles.css"],
  "files": ["dist", "src/styles"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zinhodelta3-arch/ZERU-UI---AI-libray-CSS-on-bootstrap-tailwind-css.git",
    "directory": "packages/tailwind"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "zeroui-core": "^0.1.0",
    "class-variance-authority": "latest"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "react": "latest",
    "tailwindcss": "latest"
  }
}
