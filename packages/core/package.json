{
  "name": "zeroui-core",
  "version": "0.1.0",
  "description": "Shared tokens, hooks, types and utilities for ZERU UI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "src"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zinhodelta3-arch/ZERU-UI---AI-libray-CSS-on-bootstrap-tailwind-css.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "react": "latest"
  }
}
